{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "stock": {
      "type": "integer",
      "required": true
    },
    "sku": {
      "type": "string",
      "unique": true
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "blocks"
    },
    "shortDescription": {
      "type": "string"
    },
    "oldPrice": {
      "type": "decimal"
    },
    "attributes": {
      "type": "component",
      "component": "product.product-attribute",
      "repeatable": true
    },
    "seo": {
      "type": "component",
      "component": "seo.shared-seo",
      "repeatable": true
    },
    "product_variants": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-variant.product-variant",
      "mappedBy": "product"
    },
    "order_item": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::order-item.order-item",
      "mappedBy": "product"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "product"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "products"
    },
    "inverter": {
      "type": "boolean",
      "required": true
    },
    "btu": {
      "type": "integer",
      "required": true
    },
    "roomArea": {
      "type": "integer",
      "required": true
    },
    "noiseLevel": {
      "type": "integer",
      "required": true
    },
    "wifi": {
      "type": "boolean"
    },
    "energyClass": {
      "type": "enumeration",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "installationType": {
      "type": "enumeration",
      "enum": [
        "wall",
        "cassette",
        "duct",
        "floor"
      ]
    }
  }
}
