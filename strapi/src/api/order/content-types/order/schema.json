{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "orders"
    },
    "orderNumber": {
      "type": "uid"
    },
    "orderStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "shipped",
        "completed",
        "cancelled"
      ]
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "failed",
        "refunded",
        "cancelled"
      ]
    },
    "totalPrice": {
      "type": "integer"
    },
    "shippingPrice": {
      "type": "decimal"
    },
    "paymentMethod": {
      "type": "string"
    },
    "shippingMethod": {
      "type": "string"
    },
    "customerEmail": {
      "type": "email"
    },
    "customerPhone": {
      "type": "string"
    },
    "customerName": {
      "type": "string"
    },
    "customerNotes": {
      "type": "text"
    },
    "preferredDeliveryTime": {
      "type": "string"
    },
    "order_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    },
    "shippingAddress": {
      "type": "component",
      "component": "address.shared-address",
      "repeatable": false
    },
    "stripeSessionId": {
      "type": "string"
    },
    "stripePaymentIntentId": {
      "type": "string"
    },
    "paidAt": {
      "type": "datetime"
    },
    "currency": {
      "type": "string",
      "default": "EUR"
    }
  }
}
